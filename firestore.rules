rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // /users/{userId}: cualquier usuario autenticado puede leer perfiles
    // (necesario para mostrar info del conductor en el matching), pero solo
    // el dueño puede crear/actualizar/borrar su propio documento.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if request.auth != null && request.auth.uid == userId;

      // /users/{userId}/vehicle/current
      match /vehicle/{vehicleId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // /routes/{routeId}: cualquier usuario autenticado puede leer rutas
    // activas (necesario para el matching engine). Solo el conductor dueño
    // puede crear/actualizar/borrar su propia ruta.
    match /routes/{routeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.driverId;
      allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.driverId;
    }

    // /matches/{matchId}: bloqueado hasta el Módulo 6 (booking/confirmación).
    match /matches/{matchId} {
      allow read, write: if false;
    }
  }
}
